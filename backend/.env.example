# MyFinance - Backend Environment Variables
# Copy this file to .env and adjust the values as needed

# ============================================
# DATABASE CONFIGURATION
# ============================================
# SQLite (default - good for development)
DATABASE_URL=sqlite:///./finance.db

# PostgreSQL (recommended for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/finance
# DATABASE_URL=postgresql://user:password@192.168.1.100:5432/finance

# MySQL/MariaDB
# DATABASE_URL=mysql://user:password@localhost:3306/finance

# ============================================
# SECURITY SETTINGS
# ============================================
# IMPORTANT: Generate a secure secret key for production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-change-in-production

# Token expiration settings
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# JWT algorithm (HS256 is recommended)
ALGORITHM=HS256

# ============================================
# APPLICATION SETTINGS
# ============================================
APP_NAME=MyFinance
DEBUG=false

# ============================================
# CORS SETTINGS (Frontend URLs)
# ============================================
# Add your frontend URL(s) here
# Format: JSON array of allowed origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Production:
# CORS_ORIGINS=["https://paraymn.com","https://www.paraymn.com"]

# ============================================
# EMAIL SETTINGS (SMTP)
# ============================================
# Required for password reset emails.
# If not configured, reset links will be logged to the server console instead.
#
# Gmail example:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=you@gmail.com
#   SMTP_PASSWORD=your-app-password
#   SMTP_FROM_EMAIL=you@gmail.com
#   SMTP_USE_TLS=true
#
# Outlook/Office 365:
#   SMTP_HOST=smtp.office365.com
#   SMTP_PORT=587
#
# Custom SMTP:
# SMTP_HOST=mail.yourdomain.com
# SMTP_PORT=587
# SMTP_USER=noreply@yourdomain.com
# SMTP_PASSWORD=your-smtp-password
# SMTP_FROM_EMAIL=noreply@yourdomain.com
# SMTP_USE_TLS=true

# Frontend URL (used in password reset and verification email links)
# FRONTEND_URL=http://localhost:5173
FRONTEND_URL=https://paraymn.com

# ============================================
# INITIAL ADMIN ACCOUNT (Optional)
# ============================================
# Creates an admin account on first startup if not exists
# FIRST_ADMIN_EMAIL=admin@example.com
# FIRST_ADMIN_PASSWORD=securepassword123

# ============================================
# ADMIN SETUP TOKEN (Required for /create-admin)
# ============================================
# A secret token required to create admin accounts via the web UI.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Without this token, the /create-admin page will be disabled.
# ADMIN_SETUP_TOKEN=your-secret-setup-token-here

# IPs allowed to access /create-admin (in addition to localhost)
# Format: JSON array of IP addresses
# ALLOWED_ADMIN_IPS=["203.0.113.50"]

# ============================================
# SERVER CONFIGURATION
# ============================================
# Used when running with uvicorn directly
HOST=0.0.0.0
PORT=3500

# ============================================
# DEPLOYMENT EXAMPLES
# ============================================
#
# Local Development:
#   DATABASE_URL=sqlite:///./finance.db
#   CORS_ORIGINS=["http://localhost:3000"]
#   DEBUG=true
#
# Docker (with PostgreSQL):
#   DATABASE_URL=postgresql://postgres:postgres@db:5432/finance
#   CORS_ORIGINS=["http://localhost:3000"]
#
# Production (paraymn.com):
#   DATABASE_URL=postgresql://financeuser:securepass@localhost:5432/finance
#   CORS_ORIGINS=["https://paraymn.com","https://www.paraymn.com"]
#   FRONTEND_URL=https://paraymn.com
#   SECRET_KEY=<generated-secure-key>
#   DEBUG=false
