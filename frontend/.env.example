# MyFinance - Frontend Environment Variables
# Copy this file to .env and adjust the values as needed

# API Configuration
# -----------------
# The root URL where the backend is reachable.
# The backend serves at / — a reverse proxy gives it its path (e.g. /api).
#
# Examples:
#   - Development (direct): http://localhost:3500
#   - Production (behind proxy): https://paraymn.com/api
#
VITE_API_URL=http://localhost:3500
