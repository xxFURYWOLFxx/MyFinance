# MyFinance - Frontend Environment Variables
# Copy this file to .env.local and adjust the values as needed

# API Configuration
# -----------------
# The base URL for the backend API
#
# Examples:
#   - Development with Vite proxy (default): /api
#   - Direct to local backend: http://localhost:8000/api/v1
#   - Production domain: https://api.yourfinance.com/api/v1
#   - Production IP: http://123.45.67.89:8000/api/v1
#
VITE_API_URL=/api

# Application Settings
# --------------------
# Application name (used in titles and headers)
VITE_APP_NAME=MyFinance

# Debug mode (shows additional logging in console)
VITE_DEBUG=false
